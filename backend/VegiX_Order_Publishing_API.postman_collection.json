{
  "info": {
    "name": "VegiX Order Publishing API",
    "description": "Test collection for Farmer, Broker, and Buyer order publishing functionality.\n\n## Setup Instructions\n1. Create a Postman Environment with variable:\n   - `baseUrl` = http://13.48.136.109:5000\n2. Run 'Health Check' to verify backend is running\n3. Run Login requests (Farmer/Broker/Buyer) to populate tokens:\n   - {{farmerToken}}, {{brokerToken}}, {{buyerToken}}\n4. Run 'Get Vegetables' to populate {{vegetableId}}\n5. Use the token variables for protected endpoints",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://13.48.136.109:5000"
    },
    {
      "key": "farmerToken",
      "value": ""
    },
    {
      "key": "brokerToken",
      "value": ""
    },
    {
      "key": "buyerToken",
      "value": ""
    },
    {
      "key": "vegetableId",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Utilities",
      "item": [
        {
          "name": "Health Check (Ping)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/ping",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "ping"
              ]
            }
          }
        },
        {
          "name": "Get Vegetables",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{farmerToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/vegetables",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "vegetables"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const jsonData = pm.response.json();",
                  "    const vegetables = jsonData.data || jsonData;",
                  "    if (vegetables && vegetables.length > 0) {",
                  "        pm.environment.set('vegetableId', vegetables[0]._id);",
                  "        console.log('Stored vegetableId:', vegetables[0]._id, '-', vegetables[0].name);",
                  "    }",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Register Farmer",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"John Farmer\",\n  \"email\": \"farmer1@vegix.com\",\n  \"phone\": \"0712345678\",\n  \"password\": \"password123\",\n  \"role\": \"farmer\",\n  \"location\": \"Colombo\",\n  \"company\": \"John's Farm\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/register",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "register"
              ]
            }
          }
        },
        {
          "name": "Register Broker",
          "request": {
            "method": "POST",
