              "mode": "raw",
              "raw": "{\n  \"name\": \"Jane Broker\",\n  \"email\": \"broker1@vegix.com\",\n  \"phone\": \"0787654321\",\n  \"password\": \"password123\",\n  \"role\": \"broker\",\n  \"location\": \"Colombo Market\",\n  \"company\": \"Jane's Trading\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/register",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "register"
              ]
            }
          }
        },
        {
          "name": "Register Buyer",
          "request": {
            "method": "POST",
