              "mode": "raw",
              "raw": "{\n  \"vegetableId\": \"{{vegetableId}}\",\n  \"quantity\": 100,\n  \"unit\": \"kg\",\n  \"location\": \"Colombo\",\n  \"quality\": \"premium\",\n  \"description\": \"Fresh organic vegetables from my farm\",\n  \"deliveryDate\": \"2026-03-20\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/farmer/publish-order",
              "host": [
                "{{baseUrl}}"
